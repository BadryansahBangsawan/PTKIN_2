{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "DATABASE_URL",
        "PTKIN_TOKEN_USERNAME",
        "PTKIN_TOKEN_PASSWORD",
        "PTKIN_TOKEN_URL",
        "RESEND_API_KEY",
        "MAILJET_API_KEY",
        "MAILJET_API_SECRET",
        "MAILJET_SECRET_KEY",
        "MAILJET_FROM",
        "MAILJET_FROM_EMAIL",
        "MAILJET_FROM_NAME",
        "MAILJET_SUBJECT",
        "MJ_APIKEY_PUBLIC",
        "MJ_APIKEY_PRIVATE"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:start": {
      "cache": false,
      "persistent": true
    },
    "db:stop": {
      "cache": false
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:down": {
      "cache": false
    }
  }
}
